	.breadcrumb .label {
		margin: 0 .5em 0 0;
		display: inline;
		float: left
	}

	.breadcrumb {
		margin: 0;
		float: left;
		text-transform: capitalize
	}

	.breadcrumb li,
	.breadcrumb li:before {
		margin-right: .4444444444444444em
	}

	.breadcrumb li:before {
		content: "/"
	}

	.breadcrumb li:first-child:before {
		content: "";
		margin: 0
	}

	.tabs {
		border-bottom: .05555555555555555em solid #cfcbca;
		text-decoration: none;
		background-color: #fff;
		bottom: -.05555555555555555em;
		padding: .5em .9444444444444444em .7222222222222222em;
		color: #434142;
		border-left: .05555555555555555em solid #cfcbca;
		border-right: .05555555555555555em solid #cfcbca;
		border-top: .16666666666666666em solid #00a4d8
	}

