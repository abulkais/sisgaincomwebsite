	}

	.new-blog-styles ul li {
		position: relative;
		margin-left: 1.6666666666666667em
	}

	.new-blog-styles ul li:before {
		content: "";
		position: absolute;
		left: -1.6666666666666667em;
		top: .5555555555555556em;
		-webkit-border-radius: 50%;
		-moz-border-radius: 50%;
		-o-border-radius: 50%;
		border-radius: 50%;
		width: 5px;
		height: 5px;
		background: #000
	}

	.new-blog-styles ol {
		counter-reset: new-style
	}

	.new-blog-styles ol li {
		position: relative
	}

	.new-blog-styles ol li:before {
		content: counter(new-style) ".";
		font-family: "Proxima Nova Semibold", Helvetica, Arial, "Arial Unicode", "Lucida Sans Unicode", sans-serif;
		counter-increment: new-style;
		position: absolute;
		left: -25px
