	.hover-cover--wrapper {
		position: relative;
		-webkit-transition: all .5s ease;
		-moz-transition: all .5s ease;
		transition: all .5s ease
	}

	.hover-cover--wrapper.main-image {
		background-size: 450px;
		background-position: center center
	}

	.hover-cover--wrapper:hover {
		background-size: 500px
	}

	.hover-cover--wrapper:hover .hover-cover {
		background: rgba(255, 255, 255, .7)
	}

	.hover-cover--wrapper:after {
		background: #000;
		background-color: rgba(187, 187, 187, 0);
		background-image: -webkit-gradient(linear, left top, left bottom, color-stop(0, rgba(0, 0, 0, .2)), color-stop(50%, rgba(187, 187, 187, 0)));
		background-image: -webkit-linear-gradient(top, rgba(0, 0, 0, .2), rgba(187, 187, 187, 0));
		background-image: -moz-linear-gradient(top, rgba(0, 0, 0, .2), rgba(187, 187, 187, 0));
		background-image: -ms-linear-gradient(top, rgba(0, 0, 0, .2), rgba(187, 187, 187, 0));
		background-image: -o-linear-gradient(top, rgba(0, 0, 0, .2), rgba(187, 187, 187, 0));
		background-image: linear-gradient(to bottom, rgba(0, 0, 0, .2), rgba(187, 187, 187, 0));
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 30px
	}

	.hover-cover--content {
		position: relative;
		width: 100%
	}

	.hover-cover {
		position: absolute;
		top: 0;
		bottom: 0;
		left: 0;
		width: 100%;
		background: rgba(255, 255, 255, .8);
		transition: all .5s ease-in-out
	}

