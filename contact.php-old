	.line-break {
		position: relative;
		padding-bottom: 1.25em;
		margin-bottom: 1.25em
	}

	.line-break:after {
		content: "";
		width: 7.5em;
		margin-left: -3.75em;
		position: absolute;
		bottom: 0;
		left: 50%;
		border-bottom: 1px solid #cfcbca
	}

	.desaturate {
		-webkit-filter: grayscale(1);
		-webkit-filter: grayscale(100%);
		-moz-filter: grayscale(100%);
		-o-filter: grayscale(100%);
		-ms-filter: grayscale(100%);
		filter: grayscale(100%);
		filter: url(/resources/images/inside-view/desaturate.svg#greyscale);
		filter: gray
	}

	.resaturate {
		-webkit-filter: grayscale(0);
		-moz-filter: grayscale(0);
		-o-filter: grayscale(0);
		-ms-filter: grayscale(0);
		filter: grayscale(0);
		filter: url(/resources/images/inside-view/desaturate.svg#normal);
		filter: none
	}

	.js .flickr-set .placeholder-image {
		width: 1px;
		height: 1px;
		padding: 0;
		position: absolute;
		clip: rect(1px 1px 1px 1px);
		clip: rect(1px, 1px, 1px, 1px);
		border: 0;
		overflow: hidden
	}

	.js .flickr-set .placeholder-image.focusable:active,
	.js .flickr-set .placeholder-image.focusable:focus {
		width: auto;
		height: auto;
		margin: 0;
		clip: auto;
		overflow: visible;
		position: static
	}

	none:hover .js .flickr-set .placeholder-image a,
	none:hover .js .flickr-set .placeholder-image button,
	none:hover .js .flickr-set .placeholder-image input {
		display: none
	}

	.team-photos img {
		-webkit-border-radius: 1000em;
		-moz-border-radius: 1000em;
		-o-border-radius: 1000em;
		border-radius: 1000em;
		-webkit-filter: grayscale(1);
		-webkit-filter: grayscale(100%);
		-moz-filter: grayscale(100%);
		-o-filter: grayscale(100%);
		-ms-filter: grayscale(100%);
		filter: grayscale(100%);
		filter: url(/resources/images/inside-view/desaturate.svg#greyscale);
		filter: gray;
		width: 100%
	}

	.team-photos img:focus,
