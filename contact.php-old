	}

	.blog-list-item .blog-gradient:before {
		content: attr(data-text);
		position: absolute;
		left: 0;
		top: 0;
		-webkit-mask-image: none;
		color: #000;
		font-size: 1.2em;
		font-weight: 400;
		opacity: 0;
		width: 100%
	}

	.blog-list-item:hover .blog-gradient:before {
		content: attr(data-text);
		-webkit-mask-image: none;
		color: #2575ae;
		opacity: 1
	}

	.blog-list-item:hover .blog-gradient .blog-link {
		position: relative;
		color: #f37b83;
		-webkit-mask-image: -webkit-linear-gradient(left, transparent 0, #000 100%);
		-moz-mask-image: -moz-linear-gradient(left, transparent 0, #000 100%);
		-o-mask-image: -o-linear-gradient(left, transparent 0, #000 100%);
		mask-image: linear-gradient(to right, transparent 0, #000 100%)
	}

	.blog-gradient a strike,
	.blog-gradient:hover a strike {
