	}

	.figure.float-left,
	.figure.float-right {
		float: none
	}

	.figure img {
		display: block
	}

	.circle {
		border-radius: 1000em
	}

	.slider-control-none {
		text-align: center;
		display: none;
		padding-left: 0
	}

	.slider-control-none li {
		display: inline;
		list-style: none;
		padding: .2222222222222222em .2222222222222222em .1111111111111111em .4444444444444444em;
		background: #434142
	}

	.slider-control-none a {
		display: inline-block;
		width: .8333333333333334em;
		height: .8333333333333334em;
		text-indent: -200%;
		overflow: hidden;
		background: #312f30;
		-webkit-border-radius: 1000em;
		-moz-border-radius: 1000em;
		-o-border-radius: 1000em;
		border-radius: 1000em
	}

	.lte7 .slider-control-none a {
		display: inline;
		zoom: 1
	}

	.bubble:after,
	.input-label,
	.lte7 .slider-control-none.forceful a,
	.slider-control-none.forceful a,
	.slider-control-none.forceful li {
		display: block
	}

	.slider-control-none li:first-child {
		padding-left: .2222222222222222em;
		-webkit-border-bottom-left-radius: 1000em;
		-webkit-border-top-left-radius: 1000em;
		-moz-border-radius-bottomleft: 1000em;
		-moz-border-radius-topleft: 1000em;
		-o-border-bottom-left-radius: 1000em;
		-o-border-top-left-radius: 1000em;
		border-bottom-left-radius: 1000em;
		border-top-left-radius: 1000em
	}

	.slider-control-none li:last-child {
		-webkit-border-bottom-right-radius: 1000em;
		-webkit-border-top-right-radius: 1000em;
		-moz-border-radius-bottomright: 1000em;
		-moz-border-radius-topright: 1000em;
		-o-border-bottom-right-radius: 1000em;
		-o-border-top-right-radius: 1000em;
		border-bottom-right-radius: 1000em;
		border-top-right-radius: 1000em
	}

	.slider-control-none a.slider-active,
	.slider-control-none a:focus,
	.slider-control-none a:hover {
		background: #a6ce39
	}

	.slider-direction-none {
		margin: 0;
		padding: 0;
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		list-style: none
	}

	.slider-direction-none a {
		width: 42px;
		height: 42px;
		margin: 0 0 -12px;
		display: block;
		color: #cfcbca;
		text-decoration: none;
		overflow: hidden;
		position: absolute;
		bottom: 0;
		background: #616161;
		background: rgba(97, 97, 97, .8)
	}

	.slider-direction-none a .data-icon {
		width: 38px;
		font-size: 20px;
		line-height: 42px;
		text-align: center
	}

	.slider-direction-none a:focus,
	.slider-direction-none a:hover {
		color: #fff;
		background: #434142
	}

	.slider-direction-none .slider-next {
		text-align: right;
		right: 0
	}

	.flickr-set .slider-direction-none a {
		margin-bottom: 0
	}

