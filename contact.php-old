	}

	.hexagon {
		position: absolute;
		top: 110px;
		width: 227px;
		height: 173px;
		background-color: transparent;
		margin-top: 87px;
		margin-left: -112px;
		left: 50%
	}

	.hexagon:after,
	.hexagon:before {
		content: "";
		position: absolute;
		width: 159px;
		height: 160px;
		-webkit-transform: scaleY(.5774) rotate(-45deg);
		-ms-transform: scaleY(.5774) rotate(-45deg);
		transform: scaleY(.5774) rotate(-45deg);
		background-color: inherit;
		left: 32px
	}

	.hexagon:before {
		top: -81.07px;
		border-top: solid 1px #fff
	}

	.hexagon:after {
		bottom: -81.07px;
		border-bottom: solid 1px #fff
	}

	.hexagon span {
		display: block;
		position: absolute;
		top: 3px;
		left: 0;
		height: 167px;
		background: inherit
	}

	.blog-list {
