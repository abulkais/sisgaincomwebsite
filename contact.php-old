	}

	.error input,
	.error select,
	.error textarea {
		color: #ed2b2c;
		background-color: #fef5f5
	}

	.bubble {
		margin: 0;
		padding: .6666666666666666em;
		background-color: #fff;
		-webkit-box-shadow: 0 0 .4375em rgba(0, 0, 0, .5);
		-moz-box-shadow: 0 0 .4375em rgba(0, 0, 0, .5);
		-o-box-shadow: 0 0 .4375em rgba(0, 0, 0, .5);
		box-shadow: 0 0 .4375em rgba(0, 0, 0, .5);
		-webkit-transition: opacity .15s linear;
		-moz-transition: opacity .15s linear;
		-o-transition: opacity .15s linear;
		transition: opacity .15s linear
	}

	.bubble:after {
		position: absolute;
		border: .3125em solid transparent;
		content: "";
		width: 0;
		height: 0;
		margin: 0;
		padding: 0
	}

	.bubble.left-wisp:after,
	.bubble.right-wisp:after {
		top: 50%;
		margin-top: -.3125em
	}

	.bubble.left-wisp:after {
		left: -.625em;
		border-right-color: #fff
	}

	.bubble.right-wisp:after {
		right: -.625em;
		border-left-color: #fff
	}

	.bubble.bottom-wisp:after,
	.bubble.top-wisp:after {
		left: 50%;
		margin-left: -.3125em
	}

	.bubble.top-wisp:after {
		top: -.625em;
		border-bottom-color: #fff
	}

	.bubble.bottom-wisp:after {
		bottom: -.625em;
		border-top-color: #fff
	}

	.bubble.input-alert {
		padding: .6666666666666666em;
		border-top: .375em solid #434142;
		position: absolute;
		top: 100%;
		font-family: "Proxima Nova Regular", Helvetica, Arial, "Arial Unicode", "Lucida Sans Unicode", sans-serif;
		font-size: 16px;
		font-size: 1rem;
		line-height: 1.125;
		-webkit-box-shadow: none;
		-moz-box-shadow: none;
		-o-box-shadow: none;
		box-shadow: none;
		display: inline-block
	}

	.lte7 .bubble.input-alert {
		display: inline;
		zoom: 1
	}

	none:before,
	none:hover .company-introduction a,
	none:hover .company-introduction button,
	none:hover .company-introduction input {
		display: none
	}

	.bubble.input-alert:after {
		left: .6666666666666666em;
		margin: 0;
		top: 0;
		border-top-color: #fff
	}

	.bubble.input-alert.warning {
		color: #ba7003;
		background: #fcba59;
		border-top-color: #ec8e04
	}

	.bubble.input-alert.warning:after {
		border-top-color: #ec8e04
	}

	.bubble.input-alert.info,
	.bubble.input-alert.info:after {
		border-top-color: #024f82
	}

	.bubble.input-alert.info {
		color: #013050;
		background: #048ce6
	}

	.bubble.input-alert.error {
		color: #ed2b2c;
		background: #f9b8b8;
		border-top-color: #f15a5b
	}

	.bubble.input-alert.error:after {
		border-top-color: #f15a5b
	}

	.bubble.input-alert.success {
		color: #5b9736;
		background: #abd78f;
		border-top-color: #72bc44
	}

	.bubble.input-alert.success:after {
		border-top-color: #72bc44
	}

	.no-boxshadow .bubble {
		border: .05555555555555555em solid #a9a6a7
	}

	.bubble.input-alert.form-response {
		top: inherit;
		bottom: 0;
		left: 0;
		right: 0
	}

