	<script type="text/javascript">
		$("#contactForm").on('submit', function(event) {


			var why = "";
			firstname = $("#firstnameContact").val();
			ContactNo = $("#ContactNoContact").val();
			Emailid = $("#EmailidContact").val();
			message = $("#messageContact").val();
			CaptchaInput5 = $("#CaptchaInput5").val();



			if (firstname == "") {
				why += "- Name is required.\n";
			}


			if (ContactNo == "") {
				why += "- Contact no. is required.\n";
			}

			if (Emailid == "") {
				why += "- Email is required.\n";
			}

			if (Emailid != "") {
				var emailReg = /^([\w-\.]+@([\w-]+\.)+[\w-]{2,4})?$/;
				if (!emailReg.test(Emailid)) {
					why += "- Invalid Email Id.\n";
				}
			}

			if (message == "") {
				why += "- Message is required.\n";
			}

			if (CaptchaInput5 == "") {
				why += "- Captcha Code is required.\n";
			}

			if (CaptchaInput5 != "") {
				if (ValidCaptcha5(CaptchaInput5) == false) {
					why += "- The CAPTCHA Code Does Not Match.\n";
				}
			}
			if (why != "") {
				alert(why);
				return false;
			}
		});

		function checkformCon1(theform) {
			var why = "";
			var a = Math.ceil(Math.random() * 9) + '';
			var b = Math.ceil(Math.random() * 9) + '';
			var c = Math.ceil(Math.random() * 9) + '';
			var d = Math.ceil(Math.random() * 9) + '';
			var e = Math.ceil(Math.random() * 9) + '';
			var code = a + b + c + d + e;
			document.getElementById("txtCaptcha5").value = code;
			document.getElementById("CaptchaDiv5").innerHTML = code;
		}

		var a = Math.ceil(Math.random() * 9) + '';
		var b = Math.ceil(Math.random() * 9) + '';
		var c = Math.ceil(Math.random() * 9) + '';
		var d = Math.ceil(Math.random() * 9) + '';
		var e = Math.ceil(Math.random() * 9) + '';
		var code = a + b + c + d + e;

		document.getElementById("txtCaptcha5").value = code;
		document.getElementById("CaptchaDiv5").innerHTML = code;

		// Validate input against the generated number
		function ValidCaptcha5() {
			var str1 = removeSpaces5(document.getElementById('txtCaptcha5').value);
			var str2 = removeSpaces5(document.getElementById('CaptchaInput5').value);
			if (str1 == str2) {
				return true;
			} else {
				return false;
			}
		}
		// Remove the spaces from the entered and generated code
		function removeSpaces5(string) {
			return string.split(' ').join('');
		}
	</script>
